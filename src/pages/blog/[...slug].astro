---
import { getCollection, render } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';

import { EngagementDock } from '@/components/react/EngagementDock';
import { Giscus } from '@/components/react/Giscus';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const toc = headings.filter((h) => h.depth > 1 && h.depth < 4);
---

<MainLayout 
  title={post.data.title} 
  description={post.data.description}
  image={post.data.image}
>
  <header class="max-w-4xl mx-auto mb-16 text-center">
    <div class="flex items-center justify-center gap-3 text-sm text-zinc-400 mb-4 font-medium">
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </time>
      <span>•</span>
      <span>{post.data.readTime}</span>
    </div>
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-tight mb-6">
      {post.data.title}
    </h1>
    <div class="flex flex-wrap justify-center gap-4 text-sm">
      {post.data.tags.map((tag) => (
        <a 
          href={`/blog/tags/${tag.toLowerCase()}`}
          class="text-zinc-400 hover:text-zinc-300 transition-colors font-medium"
        >
          #{tag}
        </a>
      ))}
    </div>
  </header>

  <div class="flex flex-col lg:flex-row gap-12 relative">
    <!-- Sidebar / ToC -->
    {toc.length > 3 && (
      <aside class="hidden lg:block w-64 shrink-0">
        <div class="sticky top-32 space-y-4">
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-400">In this post</h2>
          <nav class="flex flex-col gap-3">
            {toc.map((h) => (
              <a 
                href={`#${h.slug}`}
                class={`text-sm transition-colors hover:text-white ${
                  h.depth === 2 ? 'text-zinc-300 font-medium' : 'text-zinc-400 pl-4'
                }`}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </div>
      </aside>
    )}

    <article class="prose prose-zinc prose-invert max-w-none flex-grow">
      <Content />

      <!-- Giscus Comments Section -->
      <div id="comments" class="mt-24 pt-12 border-t border-zinc-900 not-prose">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-white">Discussions</h2>
          <p class="text-zinc-400 mt-2">Be the first to share your thoughts or ask a question.</p>
        </div>
        <Giscus client:visible />
      </div>
    </article>
  </div>

  <EngagementDock client:load title={post.data.title} url={Astro.url.toString()} />
</MainLayout>
