---
import { getCollection, render } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';

import { EngagementDock } from '@/components/react/EngagementDock';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const toc = headings.filter((h) => h.depth > 1 && h.depth < 4);
---

<MainLayout 
  title={post.data.title} 
  description={post.data.description}
  image={post.data.image}
>
  <div class="flex flex-col lg:flex-row gap-12 relative">
    <!-- Sidebar / ToC -->
    {toc.length > 3 && (
      <aside class="hidden lg:block w-64 shrink-0">
        <div class="sticky top-32 space-y-4">
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">In this post</h2>
          <nav class="flex flex-col gap-3">
            {toc.map((h) => (
              <a 
                href={`#${h.slug}`}
                class={`text-sm transition-colors hover:text-white ${
                  h.depth === 2 ? 'text-zinc-400 font-medium' : 'text-zinc-500 pl-4'
                }`}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </div>
      </aside>
    )}

    <article class="prose prose-zinc prose-invert max-w-none flex-grow">
      <header class="not-prose mb-12">
        <div class="flex items-center gap-3 text-sm text-zinc-500 mb-4 font-medium">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>
          <span>•</span>
          <span>{post.data.readTime}</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-white leading-tight mb-4">
          {post.data.title}
        </h1>
        <div class="flex flex-wrap gap-2 text-sm">
          {post.data.tags.map((tag) => (
            <a 
              href={`/blog/tags/${tag.toLowerCase()}`}
              class="text-zinc-500 hover:text-zinc-300 transition-colors font-medium"
            >
              #{tag}
            </a>
          ))}
        </div>
      </header>

      <Content />

      <!-- Giscus Comments Section -->
      <div id="comments" class="mt-24 pt-12 border-t border-zinc-900 not-prose">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-white">Discussions</h2>
          <p class="text-zinc-500 mt-2">Be the first to share your thoughts or ask a question.</p>
        </div>
        <script
          src="https://giscus.app/client.js"
          data-repo="jordan-thirkle/creator-hub-comments"
          data-repo-id="R_kgDOSLv_Ag"
          data-category="Announcements"
          data-category-id="DIC_kwDOSLv_As4C7nrE"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="top"
          data-theme="transparent_dark"
          data-lang="en"
          crossorigin="anonymous"
          async
          data-astro-rerun
        ></script>
      </div>
    </article>
  </div>

  <EngagementDock client:load />
</MainLayout>
