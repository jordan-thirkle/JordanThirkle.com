---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import ProjectCard from '@/components/astro/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = "Projects | Jordan Thirkle";
const description = "A collection of my recent SaaS, Games, and Open Source projects.";
---

<MainLayout title={title} description={description}>
  <div class="space-y-12">
    <header class="space-y-4">
      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight">Work</h1>
      <p class="text-zinc-400 text-lg max-w-2xl">
        A selection of my recent SaaS and open-source projects.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </div>
</MainLayout>
