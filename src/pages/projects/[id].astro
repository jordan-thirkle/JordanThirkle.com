---
import { getCollection, render } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import { EngagementDock } from '@/components/react/EngagementDock';
import { Giscus } from '@/components/react/Giscus';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<MainLayout title={project.data.title} description={project.data.description} image={project.data.image}>
  <article class="space-y-12">
    <header class="space-y-8 text-center">
      <div class="space-y-4">
        <h1 class="text-4xl md:text-6xl font-bold text-white tracking-tight leading-tight">
          {project.data.title}
        </h1>
        <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed">
          {project.data.description}
        </p>
      </div>

      <!-- Quick Info Bar -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 p-6 bg-zinc-900/50 border border-zinc-800 rounded-2xl">
        <div class="space-y-1">
          <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">Tech Stack</p>
          <p class="text-sm font-medium text-zinc-300">{project.data.tech.join(', ')}</p>
        </div>
        <div class="space-y-1">
          <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">Timeline</p>
          <p class="text-sm font-medium text-zinc-300">{project.data.timeline || 'Continuous'}</p>
        </div>
        <div class="space-y-1">
          <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">Category</p>
          <p class="text-sm font-medium text-zinc-300">{project.data.category}</p>
        </div>
        <div class="space-y-1">
          <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">Links</p>
          <div class="flex gap-3">
            {project.data.liveUrl && <a href={project.data.liveUrl} class="text-white hover:text-zinc-400 transition-colors" title="Live Demo"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a>}
            {project.data.githubUrl && <a href={project.data.githubUrl} class="text-white hover:text-zinc-400 transition-colors" title="GitHub Source"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg></a>}
            {project.data.xThreadUrl && <a href={project.data.xThreadUrl} class="text-white hover:text-zinc-400 transition-colors" title="Build in Public Thread"><svg viewBox="0 0 24 24" aria-hidden="true" class="w-4 h-4 fill-current"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg></a>}
          </div>
        </div>
      </div>

      <div class="aspect-video w-full overflow-hidden rounded-3xl border border-zinc-800 bg-zinc-900">
        <Image 
          src={project.data.image} 
          alt={project.data.title}
          width={1920}
          height={1080}
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
        />
      </div>
    </header>

    {project.data.mission && (
      <section class="p-8 bg-zinc-900 border border-zinc-800 rounded-3xl relative overflow-hidden">
        <div class="relative z-10">
          <h2 class="text-lg font-bold text-white mb-4 uppercase tracking-widest text-zinc-400 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            The Mission
          </h2>
          <p class="text-xl md:text-2xl font-medium text-zinc-200 leading-snug">
            "{project.data.mission}"
          </p>
        </div>
      </section>
    )}

    <div class="prose prose-invert prose-zinc max-w-3xl mx-auto prose-headings:font-bold prose-a:text-white hover:prose-a:text-zinc-300 transition-colors prose-img:rounded-3xl">
      <Content />
    </div>

    <!-- Giscus Comments Section -->
    <div id="comments" class="mt-24 pt-12 border-t border-zinc-900 not-prose">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-white">Project Discussion</h2>
        <p class="text-zinc-400 mt-2">Questions about the architecture or implementation? Drop a comment below.</p>
      </div>
      <Giscus client:visible />
    </div>
  </article>

  <EngagementDock client:load title={project.data.title} url={Astro.url.toString()} />
</MainLayout>
