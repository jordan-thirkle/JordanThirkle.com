---
import MainLayout from '@/layouts/MainLayout.astro';

const equipment = [
  {
    category: "Hardware",
    items: [
      { name: "MacBook Pro M3 Max", description: "The powerhouse for everything." },
      { name: "Pro Display XDR", description: "Vibrant colors for dev and design." },
      { name: "Keychron Q1 Pro", description: "Satisfying tactile feedback." },
    ]
  },
  {
    category: "Software",
    items: [
      { name: "VS Code", description: "My primary workstation." },
      { name: "Arc Browser", description: "A cleaner web experience." },
      { name: "Warp", description: "Modern terminal with AI integration." },
    ]
  }
];
---

<MainLayout title="Uses" description="A look at the gear and software I use daily.">
  <header class="mb-16">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-white mb-4">Uses</h1>
    <p class="text-lg text-zinc-500">The tools and technologies I use to build digital products.</p>
  </header>

  <div class="space-y-24">
    {equipment.map((group) => (
      <section>
        <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-4">
          {group.category}
          <div class="h-[1px] flex-grow bg-zinc-900"></div>
        </h2>
        <div class="grid gap-8">
          {group.items.map((item) => (
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
              <span class="text-lg font-bold text-zinc-200">{item.name}</span>
              <span class="text-zinc-500">{item.description}</span>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</MainLayout>
