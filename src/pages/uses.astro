---
import MainLayout from '@/layouts/MainLayout.astro';

const equipment = [
  {
    category: "Hardware",
    items: [
      { name: "MacBook M4 Air 15\"", description: "The ultimate portable workhorse.", href: "https://www.apple.com/macbook-air/" },
      { name: "Pro Display XDR", description: "Vibrant colors for dev and design.", href: "https://www.apple.com/pro-display-xdr/" },
      { name: "Keychron Q1 Pro", description: "Satisfying tactile feedback.", href: "https://www.keychron.com/products/keychron-q1-pro-qmk-via-wireless-custom-mechanical-keyboard" },
    ]
  },
  {
    category: "Software & AI",
    items: [
      { name: "Antigravity", description: "My primary AI coding partner.", href: "#" },
      { name: "Gemini AI", description: "Deepmind's most capable model.", href: "https://gemini.google.com/" },
      { name: "Claude AI", description: "Sophisticated reasoning and writing.", href: "https://claude.ai/" },
      { name: "ChatGPT", description: "Versatile daily assistant.", href: "https://chatgpt.com/" },
      { name: "Grok", description: "Real-time info and edgy insights.", href: "https://x.ai/" },
      { name: "VS Code", description: "My primary workstation.", href: "https://code.visualstudio.com/" },
      { name: "Arc Browser", description: "A cleaner web experience.", href: "https://arc.net/" },
      { name: "Warp", description: "Modern terminal with AI integration.", href: "https://www.warp.dev/" },
    ]
  }
];
---

<MainLayout title="Uses" description="A look at the gear and software I use daily.">
  <header class="mb-20 text-center">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white mb-6">Uses</h1>
    <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed">
      A curated list of the gear, software, and technologies I use to build digital products at the highest level.
    </p>
  </header>

  <div class="mb-24">
    <div class="aspect-[21/9] w-full rounded-[2.5rem] overflow-hidden border border-zinc-900 bg-zinc-950 relative group">
      <img 
        src="/assets/software/ai-tools.png" 
        alt="AI Software Stack" 
        class="w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity duration-700"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent"></div>
      <div class="absolute bottom-8 left-8">
        <p class="text-[10px] font-mono font-bold tracking-[0.3em] text-zinc-500 uppercase mb-2">Primary Stack</p>
        <h2 class="text-2xl font-bold text-white tracking-tight">AI-Native Ecosystem</h2>
      </div>
    </div>
  </div>

  <div class="space-y-24">
    {equipment.map((group) => (
      <section>
        <div class="flex items-center gap-4 mb-10">
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-400 whitespace-nowrap">{group.category}</h2>
          <div class="h-px w-full bg-zinc-900"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {group.items.map((item) => (
            <a 
              href={item.href}
              target="_blank"
              class="p-6 bg-zinc-950 border border-zinc-900 rounded-3xl hover:border-zinc-800 transition-all group"
            >
              <h3 class="text-lg font-bold text-white mb-1 group-hover:text-zinc-200 transition-colors flex items-center justify-between">
                {item.name}
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-700 group-hover:text-zinc-400 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </h3>
              <p class="text-sm text-zinc-400 leading-relaxed">{item.description}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</MainLayout>
