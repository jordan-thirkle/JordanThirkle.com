---
import MainLayout from '@/layouts/MainLayout.astro';

const equipment = [
  {
    category: "Hardware",
    items: [
      { name: "MacBook Pro M3 Max", description: "The powerhouse for everything.", href: "https://www.apple.com/macbook-pro/" },
      { name: "Pro Display XDR", description: "Vibrant colors for dev and design.", href: "https://www.apple.com/pro-display-xdr/" },
      { name: "Keychron Q1 Pro", description: "Satisfying tactile feedback.", href: "https://www.keychron.com/products/keychron-q1-pro-qmk-via-wireless-custom-mechanical-keyboard" },
    ]
  },
  {
    category: "Software",
    items: [
      { name: "VS Code", description: "My primary workstation.", href: "https://code.visualstudio.com/" },
      { name: "Arc Browser", description: "A cleaner web experience.", href: "https://arc.net/" },
      { name: "Warp", description: "Modern terminal with AI integration.", href: "https://www.warp.dev/" },
    ]
  }
];
---

<MainLayout title="Uses" description="A look at the gear and software I use daily.">
  <header class="mb-20">
    <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-white mb-6">Uses</h1>
    <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
      A curated list of the gear, software, and technologies I use to build digital products at the highest level.
    </p>
  </header>

  <div class="space-y-24">
    {equipment.map((group) => (
      <section>
        <div class="flex items-center gap-4 mb-10">
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500 whitespace-nowrap">{group.category}</h2>
          <div class="h-px w-full bg-zinc-900"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {group.items.map((item) => (
            <a 
              href={item.href}
              target="_blank"
              class="p-6 bg-zinc-950 border border-zinc-900 rounded-3xl hover:border-zinc-800 transition-all group"
            >
              <h3 class="text-lg font-bold text-white mb-1 group-hover:text-zinc-200 transition-colors flex items-center justify-between">
                {item.name}
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-700 group-hover:text-zinc-400 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </h3>
              <p class="text-sm text-zinc-500 leading-relaxed">{item.description}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</MainLayout>
