---
import MainLayout from '@/layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/astro/ProjectCard.astro';

const featuredProjects = await getCollection('projects', ({ data }) => {
  return data.featured === true;
});

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<MainLayout 
  title="Full-Stack Developer & Architect" 
  description="The digital home of Jordan Thirkle. Specialist in high-performance web applications, minimalist architecture, and building products with Astro and React."
>
  <!-- Hero Section -->
  <section class="mb-24 mt-12">
    <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-white mb-6 leading-none">
      Building digital <span class="bg-gradient-to-r from-zinc-50 to-zinc-400 bg-clip-text text-transparent">experiences</span> that stick.
    </h1>
    <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
      I'm a Full-Stack Developer and Architect specializing in high-performance web applications using Astro and React.
    </p>
    
    <div class="mt-10 flex flex-wrap gap-4">
      <a href="/projects" class="px-8 py-3 bg-white text-zinc-950 font-bold rounded-full hover:bg-zinc-200 transition-colors shadow-lg">
        View Portfolio
      </a>
      <a href="/blog" class="px-8 py-3 bg-zinc-900 text-white font-bold border border-zinc-800 rounded-full hover:border-zinc-700 transition-colors">
        Read Blog
      </a>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="mb-24">
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-3xl font-bold text-white tracking-tight">Featured Work</h2>
        <p class="text-zinc-500 mt-2">A selection of my recent SaaS and open-source projects.</p>
      </div>
      <a href="/projects" class="px-6 py-2 bg-zinc-900 text-zinc-300 font-semibold border border-zinc-800 rounded-full hover:border-zinc-700 hover:text-white transition-all text-sm">
        View All Projects
      </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <!-- Blog List -->
  <section>
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-3xl font-bold text-white tracking-tight">Latest Writing</h2>
        <p class="text-zinc-500 mt-2">Deep dives into software architecture and minimalism.</p>
      </div>
      <a href="/blog" class="text-sm font-semibold text-zinc-400 hover:text-white transition-colors">
        Read Archive →
      </a>
    </div>

    <div class="space-y-8">
      {latestPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="group flex items-start justify-between">
          <div>
            <h3 class="text-xl font-bold text-zinc-300 group-hover:text-white transition-colors mb-1">
              {post.data.title}
            </h3>
            <p class="text-sm text-zinc-500">
              {new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              <span class="mx-2">•</span>
              {post.data.readTime}
            </p>
          </div>
          <span class="text-zinc-700 group-hover:text-zinc-500 transition-transform group-hover:translate-x-1">→</span>
        </a>
      ))}
    </div>
  </section>
</MainLayout>
