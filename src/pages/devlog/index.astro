---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import { formatDate } from '@/utils/index';

const logs = (await getCollection('devlog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = "Dev Log | Jordan Thirkle";
const description = "Raw, unfiltered updates from the build. Engineering in public, day by day.";
---

<MainLayout title={title} description={description}>
  <div class="max-w-4xl mx-auto py-12">
    <header class="text-center mb-24">
      <h1 class="text-4xl md:text-6xl font-bold text-white tracking-tight mb-6">Dev Log</h1>
      <p class="text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        A technical audit trail of my shipping velocity. Raw updates, architectural pivots, and micro-wins.
      </p>
    </header>

    <div class="relative border-l border-zinc-900 ml-4 md:ml-0 md:left-1/2 md:-translate-x-px">
      {logs.map((log, index) => (
        <div class="mb-20 last:mb-0 relative">
          <!-- Timeline Dot -->
          <div class="absolute top-0 -left-1.5 md:left-1/2 md:-translate-x-1.5 w-3 h-3 rounded-full bg-zinc-800 border border-zinc-950 z-10 group-hover:scale-125 transition-transform"></div>
          
          <div class={`md:w-[calc(50%-2rem)] ${index % 2 === 0 ? 'md:mr-auto md:text-right' : 'md:ml-auto md:text-left'} ml-8 md:ml-0`}>
            <time class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-zinc-500 mb-2 block">
              {log.data.pubDate.toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'short', 
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
              })}
            </time>
            
            <a href={`/devlog/${log.id}`} class="group block">
              <h2 class="text-2xl font-bold text-white mb-4 group-hover:text-zinc-400 transition-colors">
                {log.data.title}
              </h2>
              <p class="text-sm text-zinc-400 mb-4 line-clamp-2 leading-relaxed">
                {log.data.description}
              </p>
            </a>

            <div class={`flex flex-wrap gap-2 ${index % 2 === 0 ? 'md:justify-end' : 'md:justify-start'}`}>
              {log.data.tags.map(tag => (
                <span class="text-[10px] font-mono text-zinc-500 bg-zinc-950 px-2 py-1 rounded border border-zinc-900 uppercase">
                  {tag}
                </span>
              ))}
            </div>
            
            <div class="mt-6 flex items-center gap-4 text-xs font-bold text-zinc-600">
              <a href="https://x.com/jordan_thirkle" target="_blank" class="hover:text-white transition-colors flex items-center gap-1.5">
                <svg viewBox="0 0 24 24" class="w-3 h-3 fill-current"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                VIEW ON X
              </a>
              <span class="w-1 h-1 rounded-full bg-zinc-800"></span>
              <a href={`/devlog/${log.id}`} class="hover:text-white transition-colors">
                READ LOG
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</MainLayout>
