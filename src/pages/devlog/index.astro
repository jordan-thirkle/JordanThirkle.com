---
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import { formatDate } from '@/utils/index';

const logs = (await getCollection('devlog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = "Dev Log | Jordan Thirkle";
const description = "Short, raw updates on what I'm building, learning, and shipping.";
---

<MainLayout title={title} description={description}>
  <div class="space-y-12">
    <header class="space-y-4 text-center mb-16">
      <h1 class="text-4xl md:text-6xl font-bold text-white tracking-tight">Dev Log</h1>
      <p class="text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto">
        Raw, unfiltered updates from the build. Engineering in public, day by day.
      </p>
    </header>

    <div class="space-y-16 max-w-2xl mx-auto">
      {logs.map((log) => (
        <article class="relative flex flex-col items-center text-center gap-4 group">
          <time class="text-xs font-bold uppercase tracking-widest text-zinc-600" datetime={log.data.pubDate.toISOString()}>
            {formatDate(log.data.pubDate)}
          </time>
          <h2 class="text-2xl font-bold text-white group-hover:text-zinc-400 transition-colors">
            <a href={`/devlog/${log.id}`}>
              {log.data.title}
            </a>
          </h2>
          <div class="flex flex-wrap justify-center gap-2">
            {log.data.tags.map(tag => (
              <span class="text-[10px] text-zinc-600 bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800">#{tag}</span>
            ))}
          </div>
          <div class="w-12 h-px bg-zinc-800 mt-4 group-last:hidden"></div>
        </article>
      ))}
    </div>
  </div>
</MainLayout>
