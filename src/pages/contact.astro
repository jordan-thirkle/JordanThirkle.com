---
import MainLayout from '@/layouts/MainLayout.astro';
import { CopyEmail } from '@/components/react/CopyEmail';

const socials = [
  { name: 'X / Twitter', href: 'https://x.com/jordan_thirkle', label: '@jordan_thirkle' },
  { name: 'GitHub', href: 'https://github.com/jordan-thirkle', label: 'jordan-thirkle' },
  { name: 'LinkedIn', href: 'https://linkedin.com/in/jordanthirkle', label: 'Jordan Thirkle' },
];
---

<MainLayout 
  title="Get in touch" 
  description="I'm always open to discussing new projects, open-source collaborations, or consulting opportunities."
>
  <div class="space-y-16 py-12">
    <header class="space-y-6">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-white">Get in touch.</h1>
      <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
        I'm always open to discussing new projects, open-source collaborations, or consulting opportunities.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <section class="space-y-8">
        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">Email</h2>
        <CopyEmail client:load />
      </section>

      <section class="space-y-8">
        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">Socials</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a 
            href="https://x.com/jordan_thirkle"
            target="_blank"
            class="group flex flex-col p-6 bg-zinc-900/50 border border-zinc-800 rounded-3xl hover:border-zinc-700 transition-all gap-4"
          >
            <div class="flex items-center justify-between">
              <div class="w-10 h-10 bg-zinc-800 rounded-xl flex items-center justify-center text-zinc-400 group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-700 group-hover:text-zinc-400 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </div>
            <div>
              <span class="block text-sm font-bold text-white mb-1">X / Twitter</span>
              <span class="text-xs text-zinc-500">@jordan_thirkle</span>
            </div>
          </a>

          <a 
            href="https://github.com/jordan-thirkle"
            target="_blank"
            class="group flex flex-col p-6 bg-zinc-900/50 border border-zinc-800 rounded-3xl hover:border-zinc-700 transition-all gap-4"
          >
            <div class="flex items-center justify-between">
              <div class="w-10 h-10 bg-zinc-800 rounded-xl flex items-center justify-center text-zinc-400 group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-700 group-hover:text-zinc-400 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </div>
            <div>
              <span class="block text-sm font-bold text-white mb-1">GitHub</span>
              <span class="text-xs text-zinc-500">jordan-thirkle</span>
            </div>
          </a>

          <a 
            href="https://linkedin.com/in/jordanthirkle"
            target="_blank"
            class="group flex flex-col p-6 bg-zinc-900/50 border border-zinc-800 rounded-3xl hover:border-zinc-700 transition-all gap-4"
          >
            <div class="flex items-center justify-between">
              <div class="w-10 h-10 bg-zinc-800 rounded-xl flex items-center justify-center text-zinc-400 group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-700 group-hover:text-zinc-400 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </div>
            <div>
              <span class="block text-sm font-bold text-white mb-1">LinkedIn</span>
              <span class="text-xs text-zinc-500">Jordan Thirkle</span>
            </div>
          </a>
        </div>
      </section>
    </div>
  </div>
</MainLayout>
