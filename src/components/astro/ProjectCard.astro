---
interface Props {
  project: {
    data: {
      title: string;
      description: string;
      category: string;
      tech: string[];
      heroImage: string;
    };
    id: string;
  };
}

const { project } = Astro.props;
---

<a 
  href={`/projects/${project.id}`} 
  class="group block bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden transition-all hover:border-zinc-700 hover:shadow-2xl"
>
  <div class="aspect-video bg-zinc-950 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-zinc-900 via-transparent to-transparent z-10" />
    <!-- Logic for Astro <Image /> would go here if assets are configured, using <img> for now -->
    <img 
      src={project.data.heroImage} 
      alt={project.data.title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 opacity-60 group-hover:opacity-100"
    />
  </div>
  
  <div class="p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 bg-zinc-800 px-2 py-0.5 rounded">
        {project.data.category}
      </span>
    </div>
    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-white transition-colors">
      {project.data.title}
    </h3>
    <p class="text-zinc-400 text-sm line-clamp-2">
      {project.data.description}
    </p>
    
    <div class="mt-4 flex flex-wrap gap-2">
      {project.data.tech.slice(0, 3).map((t) => (
        <span class="text-[10px] text-zinc-500">#{t}</span>
      ))}
    </div>
  </div>
</a>
