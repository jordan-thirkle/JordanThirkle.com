---
import { Image } from 'astro:assets';
interface Props {
  project: {
    data: {
      title: string;
      description: string;
      category: string;
      tech: string[];
      image: string;
    };
    id: string;
  };
}

const { project } = Astro.props;
---

<div class="group relative bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden transition-all hover:border-zinc-700 hover:shadow-2xl">
  <div class="aspect-video bg-zinc-950 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-zinc-900 via-transparent to-transparent z-10" />
    <Image 
      src={project.data.image} 
      alt={project.data.title}
      width={1280}
      height={720}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 opacity-60 group-hover:opacity-100"
    />
  </div>
  
  <div class="p-6">
    <div class="flex items-center gap-2 mb-3 relative z-20">
      <a 
        href={`/projects?filter=${project.data.category.toLowerCase()}`}
        class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 bg-zinc-800 px-2 py-0.5 rounded hover:bg-zinc-700 hover:text-white transition-colors"
      >
        {project.data.category}
      </a>
    </div>
    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-white transition-colors">
      <a href={`/projects/${project.id}`} class="after:absolute after:inset-0 after:z-10">
        {project.data.title}
      </a>
    </h3>
    <p class="text-zinc-400 text-sm line-clamp-2">
      {project.data.description}
    </p>
    
    <div class="mt-4 flex flex-wrap gap-2 relative z-20">
      {project.data.tech.slice(0, 3).map((t) => (
        <a 
          href={`/projects?filter=${t.toLowerCase()}`}
          class="text-[10px] text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          #{t}
        </a>
      ))}
    </div>
  </div>
</div>
